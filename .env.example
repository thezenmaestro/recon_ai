# =============================================================================
# ENVIRONMENT VARIABLES — copy to .env and fill in your values
# NEVER commit .env to version control
# =============================================================================

# ── Claude API ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Snowflake — shared connection params ──────────────────────────────────────
SNOWFLAKE_ACCOUNT=xy12345.us-east-1        # Your Snowflake account identifier
SNOWFLAKE_USER=RECON_SVC_USER              # Service account username
SNOWFLAKE_PASSWORD=your_password_here
SNOWFLAKE_WAREHOUSE=RECON_WH               # Compute warehouse for recon queries
SNOWFLAKE_ROLE=RECON_ROLE                  # Optional: specific role for recon

# ── Snowflake — per-database names ────────────────────────────────────────────
SNOWFLAKE_TRADES_DATABASE=TRADES_DB        # Source A: OMS / Booking system
SNOWFLAKE_EXECUTIONS_DATABASE=EXECUTIONS_DB  # Source B: Broker confirms
SNOWFLAKE_RESULTS_DATABASE=RECON_DB        # Output: Reconciliation results
SNOWFLAKE_RESULTS_SCHEMA=RESULTS           # Schema within RECON_DB

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=recon-system@yourfirm.com
SMTP_PASSWORD=your_smtp_password
EMAIL_FROM=recon-system@yourfirm.com

# ── Airflow (set on Airflow worker nodes, not just locally) ──────────────────
# NOTE: ALL variables above (Snowflake, Anthropic, Slack, SMTP) must also be
#       present on every Airflow worker node that runs this DAG. Set them via
#       your Airflow deployment's secret manager, environment injection, or
#       Airflow Connections — whichever your team uses.
#
RECON_AI_PATH=/opt/airflow/recon_ai        # Absolute path to this project on workers

# DAG identity — shown in Airflow UI and used for failure alert routing
AIRFLOW_DAG_OWNER=recon-team               # Team/user shown as DAG owner in Airflow UI
AIRFLOW_FAILURE_EMAIL=ops-team@yourfirm.com  # Email notified when the DAG task fails

# ── User activity logging (optional) ─────────────────────────────────────────
# Used to attribute manual runs in the RECON_DB.OBSERVABILITY.USER_ACTIVITY table.
# Set to the username of whoever is running manual reruns locally.
# Airflow-triggered runs are automatically attributed to "airflow".
RECON_USER=your.name@yourfirm.com
